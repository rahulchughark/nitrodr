-- fill record in this tbl_renewal_lead_task_process_record 
INSERT INTO tbl_renewal_lead_task_process_record (
    lead_id,
    program_initiation_date,
    program_start_date,
    renewal_date,
    financial_year_start,
    financial_year_end
)
SELECT 
    o.id AS lead_id,
    o.program_initiation_date,
    o.program_start_date,
    MAX(t.created_at) AS renewal_date,
    CASE 
        WHEN MONTH(MAX(t.created_at)) >= 4 THEN YEAR(MAX(t.created_at))
        ELSE YEAR(MAX(t.created_at)) - 1
    END AS financial_year_start,
    CASE 
        WHEN MONTH(MAX(t.created_at)) >= 4 THEN YEAR(MAX(t.created_at)) + 1
        ELSE YEAR(MAX(t.created_at))
    END AS financial_year_end
FROM 
    orders o
JOIN 
    tbl_lead_product_opportunity t ON o.id = t.lead_id
LEFT JOIN 
    tbl_renewal_lead_task_process_record r ON r.lead_id = o.id
WHERE 
    o.agreement_type = 'Renewal'
    AND t.status = 1
    AND r.lead_id IS NULL
    AND DATE(t.created_at) <= '2025-05-15'
GROUP BY 
    o.id, o.program_initiation_date, o.program_start_date;


