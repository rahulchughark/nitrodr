INSERT INTO lead_modify_log (
    lead_id,
    type,
    previous_name,
    modify_name,
    created_date,
    created_by,
    log_status
)
SELECT 
    o.id AS lead_id,
    'Stage' AS type,
    'Opportunity Convertion' AS previous_name,
    'Quote' AS modify_name,
    lm.created_date,
    lm.created_by,
    'Active' AS log_status
FROM orders o
JOIN lead_modify_log lm 
    ON lm.lead_id = o.id
   AND lm.previous_name = 'Lead'
   AND lm.modify_name = 'Opportunity'
WHERE o.stage = 'Quote'
AND NOT EXISTS (
    SELECT 1 
    FROM lead_modify_log l2
    WHERE l2.lead_id = o.id
      AND l2.type = 'Stage'
      AND l2.modify_name = 'Quote'
);

