/*
	===============================
			@Import	Mixins
	===============================
*/
.nav.nav-tabs {
  border: none;
}
.nav.nav-tabs li.nav-item button.nav-link {
  border: none;
  font-weight: 500;
  padding: 8px 14px;
  letter-spacing: 1px;
  color: #506690;
  background: transparent;
}
.nav.nav-tabs li.nav-item button.nav-link svg {
  vertical-align: text-bottom;
  stroke-width: 1.6;
  width: 20px;
  height: 20px;
}
.nav.nav-tabs li.nav-item button.nav-link.active {
  border-bottom: 1.6px solid #4361ee;
  color: #4361ee;
  font-weight: 600;
}
.nav.nav-tabs li.nav-item button.nav-link.active svg {
  color: #4361ee;
}
.nav.nav-tabs li.nav-item button.nav-link:disabled {
  opacity: 0.5;
}
.nav.nav-pills {
  border: none;
  padding: 0px;
  border-radius: 8px;
}
.nav.nav-pills li.nav-item button.nav-link {
  border: none;
  font-weight: 500;
  padding: 4px 14px;
  letter-spacing: 1px;
  color: #1B274D;
  background: rgba(134, 201, 208, .30196078431372547);
  border-bottom-right-radius:0px;
  border-bottom-left-radius:0px;
}
.nav.nav-pills li.nav-item button.nav-link svg {
  vertical-align: text-bottom;
  stroke-width: 1.6;
  color: #4361ee;
  width: 15px;
  height: 21px;
}
.nav.nav-pills li.nav-item button.nav-link.active {
  border-bottom: none;
  background: linear-gradient(135deg, rgba(251, 159, 100, .5), rgba(251, 159, 100, .1));

  box-shadow: 1px 1px 4px 0 rgba(0, 0, 0, 0.2);
  font-weight: 600;
}
.nav.nav-pills li.nav-item button.nav-link:disabled {
  opacity: 0.5;
}
.nav.nav-pills[aria-orientation=vertical] button.nav-link {
  border: none;
  font-weight: 500;
  padding: 8px 14px;
  letter-spacing: 1px;
  color: #1B274D;
}
.nav.nav-pills[aria-orientation=vertical] button.nav-link svg {
  vertical-align: bottom;
  stroke-width: 1.6;
  color: #1B274D;
  width: 20px;
  height: 20px;
}
.nav.nav-pills[aria-orientation=vertical] button.nav-link.active {
  border-bottom: none;
  background-color: #fff;
  box-shadow: 1px 1px 4px 0 rgba(0, 0, 0, 0.2);
}
.nav.nav-pills[aria-orientation=vertical] button.nav-link:disabled {
  opacity: 0.5;
}
.nav.nav-pills li.nav-item button.nav-link.active{    color: #1B274D;}
.nav.nav-pills li.nav-item button.nav-link svg {
    vertical-align: text-bottom;
    stroke-width: 1.6;
    color: #1B274D;
    width: 16px;
    height: 20px;
}
.tab_leads{background: #fb9f641a;
    padding: 8px;
	    border-radius: 8px;
		margin-top:-30px;}
		td svg{
			width:16px;
