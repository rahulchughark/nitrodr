 function getextention($fname){
	$fext=explode(".",$fname);
	$ext=$fext[count($fext)-1];
	return $ext;
}

function week_range($date) {
    $ts = strtotime($date);
    $start = (date('w', $ts) == 1) ? $ts : strtotime('last monday', $ts);
    return array(date('Y-m-d', $start),date('Y-m-d', strtotime('next sunday', $start)));
}
function dateDiffInDays($date1, $date2)  
{ 
    // Calulating the difference in timestamps 
    $diff = strtotime($date2) - strtotime($date1); 
      
    // 1 day = 24 hours 
    // 24 * 60 * 60 = 86400 seconds 
    return abs(round($diff / 86400)); 
}

function diffhours($startdate,$enddate){
	$starttimestamp = strtotime($startdate);
	$endtimestamp = strtotime($enddate);
	$difference = abs($endtimestamp - $starttimestamp)/3600;
	return $difference;
}

function sendMail($addTo, $addCc, $addBcc, $setSubject, $body)
{
	$emailSendType = 0 ; // 0 for phpmailer and 1 for sendgrid
	// echo "<br>";echo "<br>";echo "<br>";echo "<br>to";print_r($addTo);echo "<br>cc";print_r($addCc);echo "<br>";print_r($addBcc);echo "<br>";print_r($setSubject);echo "<br>";print_r($body);	die;
	if($emailSendType == 0)
	{
		$mail = new PHPMailer();
		// $mail = new PHPMailer();
		$mail->IsSMTP();  // set mailer to use SMTP
		$mail->Host = "smtp.office365.com";  // specify main and backup server
		$mail->SMTPAuth = true; 
		$mail->Port     = 587;
		$mail->SMTPSecure = 'tls';     // turn on SMTP authentication
		$mail->Username = "support@arkinfo.in";  // SMTP username
		$mail->Password = "Noida"; // SMTP password Noida@123
		$mail->From ='support@arkinfo.in';// 'noreply@mindbox.co.in';
		$mail->FromName = 'ICT DR Registration Portal';
		$mail->AddReplyTo("support@arkinfo.in");
		
		$mail->WordWrap = 50;    
		$mail->IsHTML(true);       
		$mail->AddReplyTo("no-reply@arkinfo.in", "No-Reply");
		
		$mail->Subject = "$setSubject";
		foreach ($addTo as $to)
		{     $mail->AddAddress("$to");    }
		if($addCc){
			foreach ($addCc as $cc)
			{		$mail->AddCC("$cc"); 	}
		}
		if($addBcc){
			foreach ($addBcc as $bcc)
			{		$mail->AddBCC("$bcc");		}
		}
		// $mail->AddAddress("pradeep.chahal@arkinfo.in");
		// $mail->addCC("virendra.kumar@arkinfo.in");

		$mail->Body = $body;
		 $a =  $mail->Send();
		// print_r($mail);
		// echo "<br>";
		// print_r(error_get_last());
		// die;
		$mail->ClearAllRecipients();
	
	}else{
		$email = new \SendGrid\Mail\Mail();
		$email->setFrom("support@arkinfo.in", "Support");
		// $sendgrid = new \SendGrid('SG.qEJFAUFrRwaVMyhIM_xXGg.uUYHJqF5Fw7F2gd5TO1ODpHgH7E_zGin9-7ZH5N9BHIjd');
		$sg_key = getSingleresult("select sg_key from sendgrid_cred limit 1");
		$sendgrid = new \SendGrid($sg_key);

		foreach ($addTo as $to)
		{     $email->addTo("$to");    }
		if($addCc){
			foreach ($addCc as $cc)
			{		$email->addCC("$cc"); 	}
		}
		if($addBcc){
			foreach ($addBcc as $bcc)
			{		$email->addBCC("$bcc");		}
		}

		$email->setSubject("$setSubject");
	    $email->addContent("text/html", $body);
	    $sendgrid->send($email);
	}
	

	

}
